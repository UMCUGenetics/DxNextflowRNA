import static TestData.*
import static TestDefaults.TEST_DATA_BASE

nextflow_process {

    name "Test Process FRASER"
    script "../main.nf"
    process "FRASER"

    config "./nextflow.config"

    tag "modules"
    tag "modules/local"
    tag "local"
    tag "fraser"
    tag "modules/fraser"


    test("Test FRASER with simulated data") {

        when {
            params {
                test_data_base = TEST_DATA_BASE
            }
            process {
                """
                input[0] = [
                    [id: "QuerySamples"],
                    [file(params.test_data_base + "/fraser_module/bam/sample1.bam")],
                    [file(params.test_data_base + "/fraser_module/bam/sample1.bam.bai")]
                ]

                input[1] = [
                    [id: "RefSamples"],
                    [
                        file(params.test_data_base + "/fraser_module/bam/sample2.bam"),
                        file(params.test_data_base + "/fraser_module/bam/sample3.bam")
                    ],
                    [
                        file(params.test_data_base + "/fraser_module/bam/sample2.bam.bai"),
                        file(params.test_data_base + "/fraser_module/bam/sample3.bam.bai")
                    ]
                ]
                """
            }
        }
        then {
            assertAll(
                {assert process.success},
                {assert snapshot(process.out.tsv).match()}
            )
        }
    }
}
