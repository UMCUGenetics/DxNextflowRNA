import static TestData.*
import static TestDefaults.TEST_DATA_BASE

nextflow_process {

    name "Test Process OUTRIDER"
    script "../main.nf"
    process "OUTRIDER"



    tag "modules"
    tag "modules/local"
    tag "local"
    tag "outrider"
    tag "modules/outrider"


    test("Test outrider with simulated data") {

        setup {
            // Stage input directories
            def input_dir = stageDir(launchDir, "outrider_module")
            def ref_dir   = stageDir(launchDir, "outrider_module/ref/")
            def query_dir = stageDir(launchDir, "outrider_module/query")


            // Download ref files into the input dir
            (2..30).each { i ->
                def idx = String.format("%02d", i) // bv. 01..30
                def name = "S${idx}.tsv"
                def url  = "${TEST_DATA_BASE}/outrider_module/ref/${name}"
                fetch(url, new File(ref_dir, name))
            }



            //Download single query file
            fetch("${TEST_DATA_BASE}/outrider_module/query/S01.tsv", new File( query_dir, "S01.tsv"))
            fetch("${TEST_DATA_BASE}/outrider_module/sim.gtf", new File(input_dir, "sim.gtf"))


        }

        when {
            params{
                input_dir = "${launchDir}/outrider_module/"
            }
            process {
                """
                input[0] = Channel
                    .fromPath(params.input_dir + "ref/*.tsv", checkIfExists: true)
                    .toList()
                    .map { files -> [ [id: "test"], file(params.input_dir + "query/S01.tsv"), files]}

                input[1] = [[id: "gencodev44"], file(params.input_dir + "sim.gtf")]

                """
            }
        }
        then {

            assertAll (
                {assert process.success},
                {assert snapshot(process.out.tsv_signif).match()}
            )
        }
    }

}
